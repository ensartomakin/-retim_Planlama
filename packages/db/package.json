    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "5.18.0"
  },
  "devDependencies": {
    "prisma": "5.18.0",
    "tsx": "4.17.0",
    "typescript": "5.5.4",
    "@types/node": "20.14.10"
  }
}
