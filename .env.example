# ============================================================
# Tekstil MES — Environment Example
# Kopyala: cp .env.example .env  ve doldur
# ============================================================

# --- Postgres (local docker-compose) ---
POSTGRES_USER=tekstil
POSTGRES_PASSWORD=change_me_now
POSTGRES_DB=tekstil_mes
DATABASE_URL="postgresql://tekstil:change_me_now@localhost:5432/tekstil_mes?schema=public"

# --- Supabase (self-hosted veya cloud) ---
NEXT_PUBLIC_SUPABASE_URL="http://localhost:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# --- App ---
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_TIMEZONE="Europe/Istanbul"
APP_LOCALE="tr-TR"

# --- DEV MODE (Supabase'siz lokal test) ---
# true  = giriş ekranını atla, otomatik SUPER_ADMIN_EMAIL olarak oturum aç
# false = normal magic-link akışı (prod)
DEV_MODE="true"

# --- Super Admin (seed sırasında ve DEV_MODE'da kullanılır) ---
SUPER_ADMIN_EMAIL="you@company.com"
SUPER_ADMIN_NAME="Sistem Sahibi"

# --- Redis (sync queue) ---
REDIS_URL="redis://localhost:6379"

# --- Mikro ERP v16 ---
MIKRO_MODE="mssql"             # mssql | rest | dummy
MIKRO_MSSQL_HOST="host.docker.internal"
MIKRO_MSSQL_PORT="1433"
MIKRO_MSSQL_USER="sa"
MIKRO_MSSQL_PASSWORD="change_me"
MIKRO_MSSQL_DATABASE="MikroDB_V16"
MIKRO_SYNC_INTERVAL_MINUTES="15"

# --- Storage (teknik çizim) ---
STORAGE_BUCKET="model-attachments"
STORAGE_MAX_FILE_MB="25"
